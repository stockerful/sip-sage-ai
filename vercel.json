{
  "version": 2,
  "buildCommand": "cd apps/frontend && pnpm run build",
  "installCommand": "cd apps/frontend && pnpm install",
  "framework": "nextjs",
  "rootDirectory": "apps/frontend",
  "outputDirectory": "apps/frontend/.next",
  "env": {
    "NODE_ENV": "production"
  },
  "ignoreCommand": "exit 0"
}
